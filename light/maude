#!/bin/bash
# maude - Quick project launcher for Claude Code
# Usage:
#   maude project-name         Create/open a project and launch Claude Code
#   maude web            Launch kanna web UI (installs Chromium if needed)
#   maude list           Show all available projects
#   maude delete <name>  Move a project to Projects/.deleted (with confirmation)
#   maude help           Show this help message
#
# Tab completion: type "maude ban<Tab>" to auto-complete project names

PROJECTS_DIR="$HOME/Maude/Projects"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

# ── Help ──────────────────────────────────────────────────────────────
show_help() {
    echo ""
    echo -e "${BOLD}maude${NC} - Quick project launcher for Claude Code"
    echo ""
    echo -e "  ${CYAN}maude project-name${NC}        Open a project (creates it if it doesn't exist)"
    echo -e "  ${CYAN}maude list${NC}                Show all available projects"
    echo -e "  ${CYAN}maude delete <name>${NC}       Delete a project (moves to .deleted/)"
    echo -e "  ${CYAN}maude web${NC}                 Launch web UI (kanna, experimental)"
    echo -e "  ${CYAN}maude tui${NC}                 Interactive project launcher (experimental)"
    echo -e "  ${CYAN}maude help${NC}                Show this help message"
    echo ""
    echo "Examples:"
    echo "  maude banana       Open or create the 'banana' project"
    echo "  maude my-app       Open or create the 'my-app' project"
    echo "  maude list         See what projects you have"
    echo ""
    echo "Tab completion:"
    echo "  Type  maude ban<Tab>  to auto-complete to 'banana'"
    echo ""
    echo "Projects are stored in: $PROJECTS_DIR"
    echo ""
}

# ── List projects ─────────────────────────────────────────────────────
list_projects() {
    # Make sure the Projects folder exists
    mkdir -p "$PROJECTS_DIR"

    # Collect project directories
    local projects=()
    for d in "$PROJECTS_DIR"/*/; do
        [[ -d "$d" ]] || continue
        projects+=("$(basename "$d")")
    done

    if [[ ${#projects[@]} -eq 0 ]]; then
        echo ""
        echo -e "${YELLOW}No projects yet!${NC}"
        echo ""
        echo "Create your first project by running:"
        echo ""
        echo "  maude my-first-project"
        echo ""
        return
    fi

    echo ""
    echo -e "${BOLD}Your projects:${NC}"
    echo ""
    for name in "${projects[@]}"; do
        local path="$PROJECTS_DIR/$name"
        if [[ -d "$path/.git" ]]; then
            echo -e "  ${GREEN}$name${NC}"
        else
            echo -e "  ${YELLOW}$name${NC}  (no git repo)"
        fi
    done
    echo ""
    echo "Open any project with:  maude project-name"
    echo ""
}

# ── Delete project ────────────────────────────────────────────────────
delete_project() {
    local name="$1"

    if [[ -z "$name" ]]; then
        echo -e "${RED}Error: Please specify a project name.${NC}" >&2
        echo "" >&2
        echo "Usage:  maude delete <project-name>" >&2
        exit 1
    fi

    local path="$PROJECTS_DIR/$name"
    local deleted_dir="$PROJECTS_DIR/.deleted"

    if [[ ! -d "$path" ]]; then
        echo -e "${RED}Error: Project '$name' does not exist.${NC}" >&2
        exit 1
    fi

    echo ""
    echo -e "${YELLOW}Are you sure you want to delete project '${BOLD}$name${NC}${YELLOW}'?${NC}"
    echo -e "  (It will be moved to ${CYAN}$deleted_dir/$name${NC})"
    echo ""
    read -r -p "Type yes or no: " answer

    case "$answer" in
        [Yy]|[Yy][Ee][Ss])
            mkdir -p "$deleted_dir"
            # If a previously deleted version exists, remove it first
            if [[ -d "$deleted_dir/$name" ]]; then
                rm -rf "$deleted_dir/$name"
            fi
            mv "$path" "$deleted_dir/$name"
            echo ""
            echo -e "${GREEN}Project '$name' moved to .deleted/${NC}"
            echo ""
            ;;
        *)
            echo ""
            echo -e "${CYAN}Delete cancelled.${NC}"
            echo ""
            ;;
    esac
}

# ── Launch TUI ────────────────────────────────────────────────────────
MAUDE_PY="$HOME/.local/bin/maude.py"
MAUDE_PY_URL="https://raw.githubusercontent.com/dirkpetersen/maude/main/light/maude.py"
MAUDE_PY_STAMP="$HOME/.maude-tui-last-update"

launch_tui() {
    # Ensure textual is installed
    if ! python3 -c "import textual" 2>/dev/null; then
        echo -e "${CYAN}Installing textual...${NC}"
        pip install --quiet textual
    fi

    # Download maude.py once a day
    local now now_s last_s
    now_s=$(date +%s)
    last_s=0
    [[ -f "$MAUDE_PY_STAMP" ]] && last_s=$(cat "$MAUDE_PY_STAMP" 2>/dev/null || echo 0)
    if [[ ! -f "$MAUDE_PY" ]] || [[ $((now_s - last_s)) -ge 86400 ]]; then
        echo -e "${CYAN}Updating maude TUI...${NC}"
        mkdir -p "$(dirname "$MAUDE_PY")"
        curl -fsSL "$MAUDE_PY_URL" -o "$MAUDE_PY" && echo "$now_s" > "$MAUDE_PY_STAMP" \
            || echo -e "${YELLOW}Warning: could not update maude.py — using cached version${NC}"
    fi

    if [[ ! -f "$MAUDE_PY" ]]; then
        echo -e "${RED}Error: maude.py not found and could not be downloaded.${NC}" >&2
        exit 1
    fi

    python3 "$MAUDE_PY"
    echo ""
    echo -e "  Please type: ${BOLD}menu${NC} <Enter> to get back to the TUI"
    echo ""
}

# ── Launch kanna web UI ───────────────────────────────────────────────
launch_web() {
    # Install kanna-code via Bun if not present
    if ! command -v kanna >/dev/null 2>&1; then
        echo -e "${CYAN}Installing kanna-code...${NC}"
        bun install -g kanna-code
        # Ensure kanna is on PATH (Bun's ~/.bun/bin may not be)
        if [[ -x "$HOME/.bun/bin/kanna" ]]; then
            ln -sfn "$HOME/.bun/bin/kanna" "$HOME/.local/bin/kanna"
        fi
    fi

    echo -e "${GREEN}Launching kanna web UI...${NC}"
    echo -e "${YELLOW}Ctrl+click the URL below to open in your Windows browser${NC}"
    echo ""
    kanna --no-open
}

# ── Main ──────────────────────────────────────────────────────────────

# No arguments → show help
if [[ $# -eq 0 ]]; then
    show_help
    exit 0
fi

# Handle special commands
case "$1" in
    help|--help|-h)
        show_help
        exit 0
        ;;
    tui)
        launch_tui
        exit 0
        ;;
    web)
        launch_web
        exit 0
        ;;
    list|ls)
        list_projects
        exit 0
        ;;
    delete|rm)
        delete_project "$2"
        exit 0
        ;;
esac

# Project name = first argument
PROJECT_NAME="$1"

# Basic name validation
if [[ "$PROJECT_NAME" =~ [^a-zA-Z0-9._-] ]]; then
    echo -e "${RED}Error: Project name can only contain letters, numbers, dots, dashes, and underscores.${NC}" >&2
    echo "" >&2
    echo "Examples of valid names:  banana, my-app, test_01, v2.0" >&2
    exit 1
fi

PROJECT_PATH="$PROJECTS_DIR/$PROJECT_NAME"

# Create the Projects folder if it doesn't exist yet
mkdir -p "$PROJECTS_DIR"

# ── Ensure Claude Code is installed ──────────────────────────────────
if ! command -v claude >/dev/null 2>&1; then
    echo -e "${YELLOW}Claude Code is not installed.${NC}"
    echo ""
    read -r -p "Install it now? [Y/n] " answer
    case "$answer" in
        [Nn]*)
            echo -e "${RED}Cannot launch projects without Claude Code.${NC}"
            exit 1
            ;;
        *)
            echo "Installing Claude Code..."
            curl -fsSL https://claude.ai/install.sh | bash -s -- -y
            export PATH="$HOME/.claude/bin:$HOME/.local/bin:$PATH"
            if ! command -v claude >/dev/null 2>&1; then
                echo -e "${RED}Installation failed. Please install manually:${NC}"
                echo "  curl -fsSL https://claude.ai/install.sh | bash"
                exit 1
            fi
            echo -e "${GREEN}Claude Code installed.${NC}"
            echo ""
            ;;
    esac
fi

# ── Refresh Maude instructions ────────────────────────────────────────
# MAUDE.md is always overwritten with the latest sandbox instructions.
# CLAUDE.md is created only if missing — users can add their own content
# but must keep the MAUDE.md include line.
refresh_claude_md() {
    mkdir -p "$HOME/.claude"
    cat > "$HOME/.claude/MAUDE.md" << 'MAUDEEOF'
# Maude Sandbox

## File Access Rules

- **Read** from `~/Maude` (top-level files) and the current project folder
  `~/Maude/Projects/<project>/`. Do NOT read from other project folders.
- **Write** only to the current project folder: `~/Maude/Projects/<project>/`.
- If the user explicitly asks you to read or write elsewhere, do so --
  but these are the defaults.

`~/Maude` is a drvfs mount shared with the Windows host. It is the
**only** path accessible from both Windows and WSL. Files the user
drags into the `Maude` folder on Windows are immediately visible here.

## Projects

Projects live in `~/Maude/Projects` which is on the shared host mount.
Your work is automatically preserved on the Windows side even if the
WSL distro is removed. `~/.claude` is also a symlink to `~/Maude/.claude`.

## Package Installation

Use `mom install -y <package>` to install system packages -- no sudo needed.
Always use `-y` for unattended installs.
MAUDEEOF
    if [[ ! -f "$HOME/.claude/CLAUDE.md" ]]; then
        cat > "$HOME/.claude/CLAUDE.md" << 'CLAUDEEOF'
<!-- DO NOT remove the line below — it loads Maude sandbox rules -->
@MAUDE.md

# User Instructions

Add your own instructions here. This file persists across reinstalls.
CLAUDEEOF
    fi
}

# ── Auto-update Claude Code once a week ──────────────────────────────
claude_maybe_update() {
    local stamp="$HOME/.claude/.last-update-check"
    local now
    now=$(date +%s)
    local last=0
    if [[ -f "$stamp" ]]; then
        last=$(cat "$stamp" 2>/dev/null || echo 0)
    fi
    local week=$((7 * 24 * 60 * 60))
    if [[ $((now - last)) -ge $week ]]; then
        echo -e "${CYAN}Checking for Claude Code updates...${NC}"
        claude update 2>/dev/null || true
        echo "$now" > "$stamp"
    fi
}

# Check if project already exists
if [[ -d "$PROJECT_PATH" ]]; then
    # Existing project
    echo -e "${GREEN}Opening project:${NC} $PROJECT_NAME"
    claude_maybe_update
    refresh_claude_md
    cd "$PROJECT_PATH"
    echo ""
    claude opus-1m --continue || exec claude opus-1m
else
    # New project → create, git init, fresh start
    echo -e "${CYAN}Creating new project:${NC} $PROJECT_NAME"
    mkdir -p "$PROJECT_PATH"
    echo -e "${GREEN}  Created folder:${NC} $PROJECT_PATH"

    git -C "$PROJECT_PATH" init --quiet
    echo -e "${GREEN}  Initialized git repo${NC}"
    refresh_claude_md
    echo ""
    cd "$PROJECT_PATH" && exec claude opus-1m
fi
